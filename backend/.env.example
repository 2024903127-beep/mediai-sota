# ─── App ─────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=MediAI
FRONTEND_URL=http://localhost:5173

# ─── Supabase ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Anthropic (Claude AI) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Google Cloud (Vision + Drive) ───────────────
GOOGLE_APPLICATION_CREDENTIALS=./src/config/google-credentials.json
GOOGLE_DRIVE_FOLDER_ID=your-root-drive-folder-id

# ─── OpenFDA ─────────────────────────────────────
OPENFDA_API_KEY=your-openfda-key
ENABLE_ONLINE_DRUG_VALIDATION=false

# ─── Encryption ──────────────────────────────────
ENCRYPTION_SECRET=your-aes-256-encryption-key-32ch

# ─── Redis (optional, for rate limiting cache) ────
REDIS_URL=redis://localhost:6379

# ─── Notifications ───────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Monitoring ──────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

